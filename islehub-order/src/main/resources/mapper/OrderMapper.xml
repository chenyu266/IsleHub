<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.islehub.order.mapper.OrderMapper">

    <resultMap id="OrderDetailMap" type="com.islehub.order.entity.Order"
               autoMapping="true">
        <id column="id" property="id"/>
        <association property="shipping" javaType="com.islehub.order.entity.OrderShipping"
                     resultMap="com.islehub.order.mapper.OrderShippingMapper.ShippingResultMap"
                     columnPrefix="os_"/>
        <collection property="items" ofType="com.islehub.order.entity.OrderItem"
                    resultMap="com.islehub.order.mapper.OrderItemMapper.ItemResultMap"
                    columnPrefix="oi_"/>
    </resultMap>

    <sql id="orderWhere">
        <if test="orderNo != null and orderNo != ''">
            AND o.order_no LIKE CONCAT('%', #{orderNo}, '%')
        </if>
        <if test="status != null and status != ''">
            AND o.status = #{status}
        </if>
        <if test="startDate != null and startDate != ''">
            AND o.created_at &gt;= #{startDate}
        </if>
        <if test="endDate != null and endDate != ''">
            AND o.created_at &lt;= #{endDate}
        </if>
    </sql>

    <select id="pageOrders" resultType="com.islehub.order.entity.Order">
        SELECT * FROM order_table o
        <where>
            <include refid="orderWhere"/>
        </where>
        ORDER BY o.created_at DESC
    </select>

    <select id="selectDetailById" resultMap="OrderDetailMap">
        SELECT o.*,
               oi.id           AS oi_id,
               oi.order_id     AS oi_order_id,
               oi.product_id   AS oi_product_id,
               oi.sku_id       AS oi_sku_id,
               oi.product_name AS oi_product_name,
               oi.sku_spec     AS oi_sku_spec,
               oi.price        AS oi_price,
               oi.quantity     AS oi_quantity,
               os.id           AS os_id,
               os.order_id     AS os_order_id,
               os.carrier      AS os_carrier,
               os.tracking_no  AS os_tracking_no,
               os.shipped_at   AS os_shipped_at,
               os.delivered_at AS os_delivered_at
        FROM order_table o
        LEFT JOIN order_item oi ON oi.order_id = o.id
        LEFT JOIN order_shipping os ON os.order_id = o.id
        WHERE o.id = #{id}
    </select>

</mapper>
